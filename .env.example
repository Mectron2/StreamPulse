# Local service ports and browser origin
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
AGGREGATOR_URL=http://localhost:3001
AGGREGATOR_REQUEST_TIMEOUT_MS=5000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=wikimedia
RABBITMQ_RAW_QUEUE=wikimedia.recentchange
RABBITMQ_RAW_ROUTING_KEY=recentchange
RABBITMQ_PROCESSED_QUEUE=wikimedia.recentchange.processed
RABBITMQ_PROCESSED_ROUTING_KEY=recentchange.processed
RABBITMQ_BINANCE_EXCHANGE=binance
RABBITMQ_BINANCE_RAW_QUEUE=binance.aggTrade
RABBITMQ_BINANCE_RAW_ROUTING_KEY=aggTrade
RABBITMQ_BINANCE_PROCESSED_QUEUE=binance.aggTrade.processed
RABBITMQ_BINANCE_PROCESSED_ROUTING_KEY=aggTrade.processed
RABBITMQ_PREFETCH=10
RABBITMQ_QUEUE_METRICS_INTERVAL_MS=10000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=stream_pulse
POSTGRES_PASSWORD=stream_pulse
POSTGRES_DB=stream_pulse
TYPEORM_SYNCHRONIZE=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CONNECT_TIMEOUT_MS=2000

# External sources
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@aggTrade

# Docker Compose Grafana credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
